# Настройки IMAP подключения
IMAP_HOST=imap.gmail.com
IMAP_USER=your-email@gmail.com
IMAP_PASSWORD=your-app-password
IMAP_MAILBOX=INBOX

# Настройки FastAPI сервера
APP_NAME=Email Automation Platform
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Файловое хранилище
SAFE_STORAGE_DIR=./storage/safe
QUARANTINE_DIR=./storage/quarantine
MAX_FILE_SIZE_MB=50

# API для отправки данных (опционально)
API_ENDPOINT=https://your-api.example.com/invoices
API_KEY=your-secret-api-key

# Настройки безопасности
ALLOWED_FILE_EXTENSIONS=.pdf,.xlsx,.docx,.xml
SCAN_INTERVAL_MINUTES=5
